# NanoBanana API key for AI-enhanced renders (get one at https://nanobananaapi.ai/api-key)
# Copy to .env or .env.local and set your key.
VITE_NANOBANANA_KEY=your_nanobanana_key_here

# OpenAI API key for AI Fusion palette suggestions (Facade Library > Fusion tab)
# Get one at https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_key_here
